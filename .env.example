# --- Required ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
AUTH_SECRET=generate-a-long-random-string

# --- First-run admin owner (used only to seed the account the first time) ---
ADMIN_EMAIL=i.alhindawi5@gmail.com
ADMIN_PASSWORD=choose-a-strong-password

# --- Email notifications & password-reset codes (Gmail App Password) ---
GMAIL_USER=i.alhindawi5@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
# NOTIFY_EMAIL=where-to-send-contact-notifications@example.com  (defaults to the owner email)

# --- Image uploads (auto-set by Vercel when you add a Blob store) ---
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# --- Cloudflare Turnstile (bot challenge on admin login; optional) ---
# Create a widget at https://dash.cloudflare.com → Turnstile. Add the hostname
# iman-hindawi.vercel.app. Leaving these unset keeps the login working without it.
# TURNSTILE_SITE_KEY=0x4AAAAAAA...        # public, sent to the browser
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...      # secret, server-side only

# --- Screenshot capture (optional; higher Microlink limits) ---
# MICROLINK_API_KEY=your-microlink-key
